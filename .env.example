# ─────────────────────────────────────────────────────────────
# GROQ AI (required for AI album sorting and memory search)
# ─────────────────────────────────────────────────────────────
# Get your FREE key at: https://console.groq.com/keys
# Groq is free, fast, and works globally (including India).
#
# For LOCAL development: rename this file to .env and fill in your key.
# For VERCEL deployment: add VITE_GROQ_API_KEY in your project's
#   Settings → Environment Variables
#
VITE_GROQ_API_KEY="your-groq-api-key-here"

# ─────────────────────────────────────────────────────────────
# App URL (used for OAuth callbacks)
# ─────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Google Photos OAuth (optional)
# ─────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────────────────────
# Spotify OAuth (optional)
# ─────────────────────────────────────────────────────────────
VITE_SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
